#!/usr/bin/env bash
set -euo pipefail
# Define paths based on your installation
QUESTA_DIR="/home/tom/install/questaSim/questasim"
VLOG="${QUESTA_DIR}/linux_x86_64/vlog"
VSIM="${QUESTA_DIR}/linux_x86_64/vsim"
echo "=== Cleaning previous work library ==="
if [ -d "work" ]; then
    rm -rf work
fi
echo "=== Creating work library ==="
vlib work
echo "=== Compiling SystemVerilog backdoor test ==="
$VLOG -64 -sv +acc tests/dpi/vpi_backdoor_compliance.sv
echo "=== Compiling C DPI/VPI wrapper directly with GCC ==="
# Compiles the shared library (.so) targeting 64-bit and including Questa headers
gcc -shared -fPIC -m64 \
    -I"${QUESTA_DIR}/include" \
    tests/dpi/vpi_backdoor_compliance.c \
    -o vpi_backdoor_compliance.so
echo "=== Running simulation ==="
# -sv_lib tells vsim to load our compiled shared library
$VSIM -64 -c -sv_lib vpi_backdoor_compliance -do "run -all; quit" vpi_backdoor_compliance
